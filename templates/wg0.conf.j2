# Managed by Ansible — do not edit manually
[Interface]
Address    = {{ wg_server_address }}
PrivateKey = {{ wg_server_private_key }}
ListenPort = {{ wg_port }}

{% for peer in wg_peers %}
[Peer]
# {{ peer.name }}
PublicKey    = {{ peer.public_key }}
PresharedKey = {{ peer.preshared_key }}
AllowedIPs   = {{ peer.allowed_ips }}

{% endfor %}
